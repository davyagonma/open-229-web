# Supabase (required for auth & data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional — used for absolute redirects in emails
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp — au moins une des deux pour activer les boutons (home + flottant)
# Lien d’invitation de groupe (recommandé)
# NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/BiwrZgvZPFYGfDuk2tN4ah
# Ou numéro seul (indicatif pays inclus, chiffres) — ouvre wa.me
# NEXT_PUBLIC_WHATSAPP_PHONE=229XXXXXXXXX
